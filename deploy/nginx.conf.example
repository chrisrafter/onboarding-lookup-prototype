# nginx reverse proxy — copy to /etc/nginx/sites-available/datablueprint-lookup
# symlink into sites-enabled, then: sudo nginx -t && sudo systemctl reload nginx
# For TLS: sudo certbot --nginx -d lookup.yourdomain.com
server {
    listen 80;
    server_name lookup.yourdomain.com;   # <-- change to your hostname

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
