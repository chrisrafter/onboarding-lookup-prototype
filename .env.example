# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# Leave ANTHROPIC_API_KEY blank to run in mock mode (no key needed).

PORT=8080

# Provider: "anthropic" for real LLM+web-search lookups, "mock" to run keyless.
# If ANTHROPIC_API_KEY is set, provider defaults to anthropic automatically.
LOOKUP_PROVIDER=

# Anthropic credentials (only needed for real lookups)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_SEARCHES=4
